# ---- Stage 1: Build stage (optional if you already have dist) ----
# If your dist folder is already built, you can remove this build stage.

FROM node:18-alpine AS builder
WORKDIR /app

# Copy package files & install
COPY package*.json ./
RUN npm install

# Copy all source code
COPY . .

# Build the project (change if needed)
RUN npm run build

# ---- Stage 2: Nginx serving ----

FROM nginx:stable-alpine

# Remove default nginx static content
RUN rm -rf /usr/share/nginx/html/*

# Copy dist folder to nginx html folder
# Change path if your dist folder name is different
COPY --from=builder /app/web/dist /usr/share/nginx/html

# Copy custom nginx config (optional)
# COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
